# Copy to .env and adjust if needed:
#   cp .env.example .env

# MySQL (used by docker-compose mysql + backend)
# Docker uses DB_APP_USER (lugha) — not root — for container-to-container access.
DB_APP_USER=lugha
DB_USER=root
DB_PASSWORD=lugha_dev_change_me
DB_HOST=mysql
DB_PORT=3306
DB_NAME=lugha_db
# If you change DB_PASSWORD after the first `docker compose up`, reset the volume:
#   docker compose down -v

# Expose MySQL on host (optional — dev only)
MYSQL_PORT=3307

# App ports on host
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Auth
JWT_SECRET=replace-with-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AI (optional)
AI_PROVIDER=mock
AI_API_KEY=
