# MySQL (used by docker-compose mysql + backend)
DB_USER=root
DB_PASSWORD=lugha_dev_change_me
DB_HOST=mysql
DB_PORT=3306
DB_NAME=lugha_db

# Expose MySQL on host (optional — dev only)
MYSQL_PORT=3307

# App ports on host
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Auth
JWT_SECRET=replace-with-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AI (optional)
AI_PROVIDER=mock
AI_API_KEY=
